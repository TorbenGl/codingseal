# ── coding-seal Podman container — environment template ───────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Source it before running scripts/run.sh:
#   set -a && source .env && set +a
#   scripts/run.sh -p ~/projects/myproject
#
# .env is listed in .gitignore — never commit secrets.

# ── Authentication (choose ONE method) ────────────────────────────────────

# Method A (recommended) — long-lived OAuth token (works with a Claude
# Pro/Max subscription, no API billing). Generate it once with:
#     scripts/run.sh --setup-token
# then paste the printed token here:
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Method B — API key from https://console.anthropic.com/account/keys
# (pay-per-token API billing)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Method C — leave both blank and run `scripts/run.sh --auth` once.
# The login is saved in the host folder ~/.codingseal/claude-auth and reused
# on every subsequent run (persisted via CLAUDE_CONFIG_DIR).

# ── SSH access ────────────────────────────────────────────────────────────

# Your public key, injected into the container's authorized_keys at startup.
# Paste the full contents of ~/.ssh/id_ed25519.pub (or similar) here.
# Required for VS Code Remote-SSH and --remote mode.
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... you@host"

# ── Optional overrides ────────────────────────────────────────────────────

# Container name (default: coding-seal)
# CONTAINER_NAME=coding-seal

# SSH port on localhost (default: 2222)
# SSH_PORT=2222

# Image to run (default: localhost/coding-seal:latest)
# CLAUDE_IMAGE=localhost/coding-seal:latest

# Host folder for persistent Claude auth (default: ~/.codingseal/claude-auth).
# A fixed path, so login persists whether run.sh is launched from a normal
# terminal or the VS Code snap (which relocates podman's named-volume storage).
# CLAUDE_AUTH_DIR=~/.codingseal/claude-auth
