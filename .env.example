# ── claude-code Podman container — environment template ───────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Source it before running scripts/run.sh:
#   set -a && source .env && set +a
#   scripts/run.sh -p ~/projects/myproject
#
# .env is listed in .gitignore — never commit secrets.

# ── Authentication (choose one method) ────────────────────────────────────

# Method A — API key (stateless, no login needed inside the container)
# Get yours at https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Method B — leave ANTHROPIC_API_KEY blank and run `claude auth login`
# inside the container on first use. The token is stored in the
# named volume `claude-auth` and reused on every subsequent run.
# ANTHROPIC_API_KEY=

# ── SSH access ────────────────────────────────────────────────────────────

# Your public key, injected into the container's authorized_keys at startup.
# Paste the full contents of ~/.ssh/id_ed25519.pub (or similar) here.
# Required for VS Code Remote-SSH and --remote mode.
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... you@host"

# ── Optional overrides ────────────────────────────────────────────────────

# Container name (default: claude-code)
# CONTAINER_NAME=claude-code

# SSH port on localhost (default: 2222)
# SSH_PORT=2222

# Image to run (default: localhost/claude-code:latest)
# CLAUDE_IMAGE=localhost/claude-code:latest

# Named volume for persistent Claude auth (default: claude-auth)
# CLAUDE_VOLUME=claude-auth
