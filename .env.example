# ── coding-seal Podman container — environment template ───────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Source it before running scripts/run.sh:
#   set -a && source .env && set +a
#   scripts/run.sh -p ~/projects/myproject
#
# .env is listed in .gitignore — never commit secrets.

# ── Authentication ────────────────────────────────────────────────────────
#
# Auth is login-only. Log in once with:
#   scripts/run.sh --auth
# A URL is printed → open it in your browser → log in → paste the code back.
# The login is saved in the host folder ~/.codingseal/claude-auth and reused on
# every subsequent run (no re-login, no prompts).
#
# Why login (and not a token/API key)? Remote Control (scripts/run.sh --rc)
# requires a full claude.ai login; long-lived tokens and API keys are rejected.
# There is nothing to set here for auth.

# ── SSH access (only needed for `scripts/run.sh --ssh`) ────────────────────

# Your PUBLIC key. run.sh bind-mounts it into the container's authorized_keys so
# you can `ssh -p 2222 coder@localhost` using your own private key. Paste the
# full contents of ~/.ssh/id_ed25519.pub (or similar) here.
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... you@host"

# ── MCP servers (optional) ─────────────────────────────────────────────────
# Context7 (up-to-date library docs) and Sequential Thinking are built in and
# always on — nothing required here. The two values below are optional:

# Context7 works anonymously (rate-limited). A free key from
# https://context7.com/dashboard raises the limits.
# CONTEXT7_API_KEY=ctx7sk-...

# Set a GitHub personal access token to ENABLE the GitHub MCP server
# (issues / PRs / repos via https://api.githubcopilot.com/mcp/). Without it, the
# GitHub server is simply not registered. Use a token with the scopes you need.
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# ── Optional overrides ────────────────────────────────────────────────────

# Container name (default: coding-seal)
# CONTAINER_NAME=coding-seal

# SSH port on localhost (default: 2222)
# SSH_PORT=2222

# Image to run (default: localhost/coding-seal:latest)
# CLAUDE_IMAGE=localhost/coding-seal:latest

# Host folder for persistent Claude login (default: ~/.codingseal/claude-auth).
# A fixed path, so login persists whether run.sh is launched from a normal
# terminal or the VS Code snap (which relocates podman's named-volume storage).
# CLAUDE_AUTH_DIR=~/.codingseal/claude-auth
